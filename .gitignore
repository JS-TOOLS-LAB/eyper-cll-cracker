# ===============================
# EYPER CLL - JS Intergrated Labs
# Git Ignore File
# ===============================

# ===============================
# SENSITIVE DATA - NEVER COMMIT
# ===============================

# User data (contains passwords hashes)
/data/
/data/*.pwd
/data/*.dat
/data/session.*
/data/user-password.pwd
/data/users.php

# Hash files (may contain sensitive hashes)
/hashes/
/hashes/*.txt
/hashes/*.hash
!/hashes/.gitkeep
!/hashes/README.md

# Wordlists (large files, may contain passwords)
/passwords/
/passwords/*.txt
/passwords/*.dic
/passwords/*.wordlist
!/passwords/.gitkeep
!/passwords/README.md
!/passwords/sample.txt

# Log files
/logs/
/logs/*.log
/logs/*.err
/logs/*.out
!/logs/.gitkeep

